{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReadMatchData",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::hackathon-data-482712210181/*"
    },
    {
      "Sid": "KinesisPutRecords",
      "Effect": "Allow",
      "Action": ["kinesis:PutRecord", "kinesis:PutRecords"],
      "Resource": "arn:aws:kinesis:us-east-1:482712210181:stream/sektor-match-events"
    },
    {
      "Sid": "DynamoMatchState",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-connections"
    }
  ]
}
