{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAnswers",
      "Effect": "Allow",
      "Action": ["dynamodb:Query"],
      "Resource": "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-answers"
    },
    {
      "Sid": "ReadWriteScores",
      "Effect": "Allow",
      "Action": [
        "dynamodb:UpdateItem",
        "dynamodb:GetItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-scores",
        "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-scores/index/score-index"
      ]
    },
    {
      "Sid": "ReadConnections",
      "Effect": "Allow",
      "Action": ["dynamodb:Query"],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-connections",
        "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-connections/index/*"
      ]
    },
    {
      "Sid": "ManageConnections",
      "Effect": "Allow",
      "Action": "execute-api:ManageConnections",
      "Resource": "arn:aws:execute-api:us-east-1:482712210181:3bodgtvae0/prod/POST/@connections/*"
    }
  ]
}
