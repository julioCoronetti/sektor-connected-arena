{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FindPostByIdIndex",
      "Effect": "Allow",
      "Action": "dynamodb:Query",
      "Resource": "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-posts/index/id-index"
    },
    {
      "Sid": "ReadAndDecrementPost",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-posts"
    },
    {
      "Sid": "RemoveLike",
      "Effect": "Allow",
      "Action": "dynamodb:DeleteItem",
      "Resource": "arn:aws:dynamodb:us-east-1:482712210181:table/sektor-likes"
    }
  ]
}
